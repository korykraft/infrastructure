use_default_settings: true

server:
  secret_key: "{{ searxng_secret_key }}"
  base_url: "{{ searxng_base_url }}"
  limiter: false
  image_proxy: true

search:
  safe_search: 0
  formats:
    - html
    - json

engines:
  - name: google
    engine: google
    disabled: false
  - name: bing
    engine: bing
    disabled: false
  - name: duckduckgo
    engine: duckduckgo
    disabled: false
  - name: github
    engine: github
    disabled: false
  - name: stackoverflow
    engine: stackoverflow
    disabled: false
  - name: hackernews
    engine: hackernews
    disabled: false
  - name: pypi
    engine: pypi
    disabled: false
  - name: npm
    engine: npm
    disabled: false
