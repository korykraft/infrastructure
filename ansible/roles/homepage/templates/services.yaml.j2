---
- Infrastructure:
    - Forgejo:
        icon: forgejo.svg
        href: http://192.168.1.84:3000
        description: Git hosting
        widget:
          type: forgejo
          url: http://192.168.1.84:3000
          key: "{{ homepage_forgejo_key | default('') }}"

    - Hermes:
        icon: si-robot
        href: https://hermes-agent.nousresearch.com/docs
        description: CLI AI Agent

- CI:
    - pictubook-app (main):
        icon: si-githubactions
        href: https://github.com/korykraft/pictubook-app/actions
        description: GitHub Actions
        widget:
          type: customapi
          url: http://ubuntu:9090/ci-status.json
          refreshInterval: 60000
          display: list
          mappings:
            - field: workflow
              label: Workflow
            - field: status
              label: Status
            - field: when
              label: Last Run
