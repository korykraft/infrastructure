services:
  forgejo:
    image: "{{ forgejo_image }}"
    container_name: "{{ forgejo_container_name }}"
    restart: unless-stopped
    env_file:
      - .env
    ports:
      - "${FORGEJO_HTTP_PORT:-3000}:3000"
      - "${FORGEJO_SSH_PORT:-2222}:22"
    volumes:
      - ${FORGEJO_DATA_DIR}:/data
      - ${FORGEJO_TIMEZONE_PATH:-/etc/timezone}:/etc/timezone:ro
      - ${FORGEJO_LOCALTIME_PATH:-/etc/localtime}:/etc/localtime:ro
